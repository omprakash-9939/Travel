PORT=5000
MONGODB_URI=mongodb://localhost:27017/dataart_travel
JWT_SECRET=change_me_to_a_long_random_secret
CLIENT_URL=http://localhost:3000
NODE_ENV=development

# ─── Flights & Hotels (Amadeus) ─── https://developers.amadeus.com/register
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_ENV=test

# ─── Weather (AI Hub) ─── https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ─── AI Chat (optional) ─── https://platform.openai.com
OPENAI_API_KEY=

# ─── Currency ─── https://www.exchangerate-api.com (optional key; free tier works without)
EXCHANGERATE_API_KEY=

# ─── Maps — use Mapbox OR Google (or both) ───
MAPBOX_ACCESS_TOKEN=
GOOGLE_MAPS_API_KEY=

# ─── Payments ───
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Email ─── https://sendgrid.com
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=bookings@yourdomain.com

# ─── SMS ─── https://www.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Personalization Engine feature flags ───
# price_drop notifications fabricate a discount % — keep OFF until backed by real
# price history (US-0601 / RC-6). Set to "true" only in environments with real data.
ENABLE_PRICE_DROP_NOTIFICATIONS=false
# Re-engagement emails to high-intent users who went quiet (US-0604 / EP-06).
ENABLE_REENGAGEMENT_EMAILS=false
# Use Claude to write notification copy; falls back to templates when unset (EP-06).
ENABLE_LLM_COPY=false
# Claude API key for notification copy generation (optional; templates used if blank).
ANTHROPIC_API_KEY=
